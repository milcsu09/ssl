
foldl = f. acc. xs.
  match xs
  | []     = acc
  | x : xs = foldl f (f acc x) xs
  ;

range = n. ns.
  | n = range (n - 1) (n : ns)
  | 1 = ns
  ;

filter = f. xs.
  match xs
  | [] = []
  | x : xs =
    (
    | f x       = x : filter f xs
    | otherwise =     filter f xs
    )
  ;

# Problem 1.
printl (foldl (+) 0 (filter (n. (n % 3 == 0) + (n % 5 == 0)) (range 999 [])));

